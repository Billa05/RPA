<Activity mc:Ignorable="sap sap2010 sads" x:Class="VerifyDocuments"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:json="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json">

  <x:Members>
    <x:Property Name="in_BaseURL" Type="InArgument(x:String)" />
    <x:Property Name="in_AppId" Type="InArgument(x:String)" />
    <x:Property Name="in_AadhaarNumber" Type="InArgument(x:String)" />
    <x:Property Name="in_ApplicantName" Type="InArgument(x:String)" />
    <x:Property Name="in_DocumentsJSON" Type="InArgument(x:String)" />
    <x:Property Name="out_AadhaarValid" Type="OutArgument(x:Boolean)" />
    <x:Property Name="out_DocsValid" Type="OutArgument(x:Boolean)" />
  </x:Members>

  <Sequence DisplayName="Verify Aadhaar and Documents for Application">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="var_AadhaarResponse" />
      <Variable x:TypeArguments="x:String" Name="var_BatchResponse" />
      <Variable x:TypeArguments="json:JObject" Name="var_AadhaarResult" />
      <Variable x:TypeArguments="json:JObject" Name="var_BatchResult" />
      <Variable x:TypeArguments="x:Boolean" Name="var_AadhaarOK" Default="False" />
      <Variable x:TypeArguments="x:Boolean" Name="var_DocsOK" Default="False" />
    </Sequence.Variables>

    <!-- ======= AADHAAR VERIFICATION ======= -->
    <TryCatch DisplayName="Verify Aadhaar">
      <TryCatch.Try>
        <Sequence DisplayName="Call Aadhaar API">
          <ui:LogMessage Level="Info"
            Message="[String.Format(&quot;  → Verifying Aadhaar: {0} for {1}&quot;, in_AadhaarNumber.ToString, in_ApplicantName.ToString)]" />

          <ui:HttpClient DisplayName="POST /api/verify/aadhaar"
            Method="POST"
            RequestUrl="http://localhost:5000/api/verify/aadhaar"
            Result="[var_AadhaarResponse]"
            AcceptFormat="JSON"
            BodyFormat="application/json"
            Body="[String.Format(&quot;{{&quot;&quot;aadhaar&quot;&quot;:&quot;&quot;{0}&quot;&quot;,&quot;&quot;name&quot;&quot;:&quot;&quot;{1}&quot;&quot;}}&quot;, in_AadhaarNumber.ToString, in_ApplicantName.ToString)]"
            Timeout="10000" />

          <Assign DisplayName="Parse Aadhaar Response">
            <Assign.To><OutArgument x:TypeArguments="json:JObject">[var_AadhaarResult]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="json:JObject">[json:JObject.Parse(var_AadhaarResponse)]</InArgument></Assign.Value>
          </Assign>

          <Assign DisplayName="Check Aadhaar Verified">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[var_AadhaarOK]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">[CBool(var_AadhaarResult("verified"))]</InArgument></Assign.Value>
          </Assign>

          <If Condition="[var_AadhaarOK]">
            <If.Then>
              <ui:LogMessage Level="Info" Message="&quot;  ✓ Aadhaar verified — identity confirmed in database&quot;" />
            </If.Then>
            <If.Else>
              <ui:LogMessage Level="Warn"
                Message="[&quot;  ✗ Aadhaar verification FAILED: &quot; &amp; var_AadhaarResult(&quot;reason&quot;).ToString()]" />
            </If.Else>
          </If>
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="aadhaarEx" />
            </ActivityAction.Argument>
            <Sequence>
              <ui:LogMessage Level="Error" Message="&quot;  ✗ Aadhaar API call failed: &quot; &amp; aadhaarEx.Message" />
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:Boolean">[var_AadhaarOK]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Boolean">False</InArgument></Assign.Value>
              </Assign>
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- ======= BATCH DOCUMENT VERIFICATION ======= -->
    <TryCatch DisplayName="Batch Verify Documents">
      <TryCatch.Try>
        <Sequence DisplayName="Call Batch Verify API">
          <ui:LogMessage Level="Info" Message="&quot;  → Running batch document verification...&quot;" />

          <ui:HttpClient DisplayName="POST /api/verify/batch"
            Method="POST"
            RequestUrl="http://localhost:5000/api/verify/batch"
            Result="[var_BatchResponse]"
            AcceptFormat="JSON"
            BodyFormat="application/json"
            Body="[String.Format(&quot;{{&quot;&quot;appId&quot;&quot;:&quot;&quot;{0}&quot;&quot;,&quot;&quot;documents&quot;&quot;:{1}}}&quot;, in_AppId.ToString, in_DocumentsJSON.ToString)]"
            Timeout="15000" />

          <Assign DisplayName="Parse Batch Response">
            <Assign.To><OutArgument x:TypeArguments="json:JObject">[var_BatchResult]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="json:JObject">[json:JObject.Parse(var_BatchResponse)]</InArgument></Assign.Value>
          </Assign>

          <Assign DisplayName="Check All Docs Valid">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[var_DocsOK]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">[CBool(var_BatchResult("allValid"))]</InArgument></Assign.Value>
          </Assign>

          <ui:LogMessage Level="Info"
            Message="[String.Format(&quot;  → Batch result: {0}/{1} documents valid — recommendation: {2}&quot;, var_BatchResult(&quot;validDocuments&quot;).ToString(), var_BatchResult(&quot;totalDocuments&quot;).ToString(), var_BatchResult(&quot;recommendation&quot;).ToString())]" />

          <If Condition="[var_DocsOK]">
            <If.Then>
              <ui:LogMessage Level="Info" Message="&quot;  ✓ All documents verified successfully&quot;" />
            </If.Then>
            <If.Else>
              <ui:LogMessage Level="Warn" Message="&quot;  ✗ Some documents failed verification&quot;" />
            </If.Else>
          </If>
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="batchEx" />
            </ActivityAction.Argument>
            <Sequence>
              <ui:LogMessage Level="Error" Message="&quot;  ✗ Batch verify API failed: &quot; &amp; batchEx.Message" />
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:Boolean">[var_DocsOK]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Boolean">False</InArgument></Assign.Value>
              </Assign>
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- Set outputs -->
    <Assign DisplayName="Set out_AadhaarValid">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[out_AadhaarValid]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[var_AadhaarOK]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_DocsValid">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[out_DocsValid]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[var_DocsOK]</InArgument></Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info"
      Message="[String.Format(&quot;  → Verification summary for {0}: Aadhaar={1}, Docs={2}&quot;, in_AppId.ToString, var_AadhaarOK, var_DocsOK)]" />

  </Sequence>
</Activity>
