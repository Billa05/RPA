<Activity mc:Ignorable="sap sap2010" x:Class="CertifyHub.RegisterAndUpload"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:json="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json">

  <!--
    Calls the API directly to:
      1. Check the attendee exists (name + ID)
      2. Register and submit documents
      3. Trigger mock verification
    Also drives the website UI to mirror what the API does.
  -->

  <x:Members>
    <x:Property Name="in_ApiBaseURL"      Type="InArgument(x:String)" />
    <x:Property Name="in_EventId"         Type="InArgument(x:String)" />
    <x:Property Name="in_AttendeeName"    Type="InArgument(x:String)" />
    <x:Property Name="in_AttendeeId"      Type="InArgument(x:String)" />
    <x:Property Name="out_RegistrationId" Type="OutArgument(x:String)" />
    <x:Property Name="out_CertificateReady" Type="OutArgument(x:Boolean)" />
  </x:Members>

  <Sequence DisplayName="Check Attendance → Register → Verify Documents">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String"       Name="AttCheckResp" />
      <Variable x:TypeArguments="json:JObject"   Name="AttCheckObj" />
      <Variable x:TypeArguments="x:Boolean"      Name="AttFound"    Default="False" />
      <Variable x:TypeArguments="x:String"       Name="RegPayload" />
      <Variable x:TypeArguments="x:String"       Name="RegResp" />
      <Variable x:TypeArguments="json:JObject"   Name="RegObj" />
      <Variable x:TypeArguments="x:String"       Name="RegId" />
      <Variable x:TypeArguments="x:String"       Name="VerifyResp" />
      <Variable x:TypeArguments="json:JObject"   Name="VerifyObj" />
      <Variable x:TypeArguments="x:Boolean"      Name="CertReady"   Default="False" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;Step 4: Checking attendance for &quot; + in_AttendeeName.ToString() + &quot; (ID: &quot; + in_AttendeeId.ToString() + &quot;)&quot;]" />

    <!-- ══ 4A: ATTENDANCE CHECK ══ -->
    <TryCatch DisplayName="4A — Verify Attendee via API">
      <TryCatch.Try>
        <Sequence>
          <ui:HttpClient DisplayName="POST /check-attendee"
            RequestUrl="[in_ApiBaseURL.ToString() + &quot;/events/&quot; + in_EventId.ToString() + &quot;/check-attendee&quot;]"
            Method="POST"
            Body="[&quot;{\&quot;name\&quot;:\&quot;&quot; + in_AttendeeName.ToString() + &quot;\&quot;,\&quot;idNumber\&quot;:\&quot;&quot; + in_AttendeeId.ToString() + &quot;\&quot;}&quot;]"
            BodyFormat="application/json"
            AcceptFormat="JSON"
            Result="[AttCheckResp]"
            Timeout="10000" />

          <Assign DisplayName="Parse attendance response">
            <Assign.To><OutArgument x:TypeArguments="json:JObject">[AttCheckObj]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="json:JObject">[json:JObject.Parse(AttCheckResp)]</InArgument></Assign.Value>
          </Assign>

          <Assign DisplayName="Get found flag">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[AttFound]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">[CBool(AttCheckObj("found"))]</InArgument></Assign.Value>
          </Assign>

          <If DisplayName="Attendance found?" Condition="[AttFound]">
            <If.Then>
              <ui:LogMessage Level="Info" Message="[&quot;  ✓ Attendance confirmed: &quot; + AttCheckObj(&quot;attendeeName&quot;).ToString()]" />
            </If.Then>
            <If.Else>
              <Sequence>
                <ui:LogMessage Level="Error" Message="[&quot;  ✗ Attendance check failed: &quot; + AttCheckObj(&quot;reason&quot;).ToString()]" />
                <Throw DisplayName="Throw — not in attendee list">
                  <Throw.Exception>
                    <InArgument x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
                      [New Exception("Attendee not found in Excel list: " + AttCheckObj("reason").ToString())]
                    </InArgument>
                  </Throw.Exception>
                </Throw>
              </Sequence>
            </If.Else>
          </If>
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument><DelegateInArgument x:TypeArguments="s:Exception" Name="ex" /></ActivityAction.Argument>
            <Sequence>
              <ui:LogMessage Level="Error" Message="[&quot;  ✗ Attendance check error: &quot; + ex.Message]" />
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:Boolean">[AttFound]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Boolean">False</InArgument></Assign.Value>
              </Assign>
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- Only continue if attendance was confirmed -->
    <If DisplayName="Continue if attendance confirmed" Condition="[AttFound]">
      <If.Then>
        <Sequence DisplayName="Register and Verify">

          <!-- UI: Type name and ID on website -->
          <TryCatch DisplayName="UI — Fill Attendance Form">
            <TryCatch.Try>
              <Sequence DisplayName="Type into website attendance check">
                <ui:TypeInto DisplayName="Type Full Name"
                  Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl id=&quot;att-name&quot; tag=&quot;INPUT&quot; /&gt;'}"
                  Text="[in_AttendeeName.ToString()]"
                  EmptyField="True" ContinueOnError="True" />

                <ui:TypeInto DisplayName="Type ID Number"
                  Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl id=&quot;att-id&quot; tag=&quot;INPUT&quot; /&gt;'}"
                  Text="[in_AttendeeId.ToString()]"
                  EmptyField="True" ContinueOnError="True" />

                <ui:Click DisplayName="Click Verify Attendance"
                  Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl tag=&quot;BUTTON&quot; innertext=&quot;Verify Attendance&quot; /&gt;'}"
                  ContinueOnError="True" />

                <Delay Duration="[TimeSpan.FromSeconds(2)]" />
                <ui:LogMessage Level="Info" Message="&quot;  ✓ Attendance form filled on website&quot;" />
              </Sequence>
            </TryCatch.Try>
            <TryCatch.Catches>
              <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
                <ActivityAction x:TypeArguments="s:Exception">
                  <ActivityAction.Argument><DelegateInArgument x:TypeArguments="s:Exception" Name="uiEx" /></ActivityAction.Argument>
                  <ui:LogMessage Level="Warn" Message="[&quot;  ⚠ UI form fill failed (API still works): &quot; + uiEx.Message]" />
                </ActivityAction>
              </Catch>
            </TryCatch.Catches>
          </TryCatch>

          <!-- ══ 4B: REGISTER + SUBMIT DOCUMENTS via API ══ -->
          <ui:LogMessage Level="Info" Message="&quot;  → Creating registration and submitting documents…&quot;" />

          <Assign DisplayName="Build registration payload">
            <Assign.To><OutArgument x:TypeArguments="x:String">[RegPayload]</OutArgument></Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">
                ["{""name"":""" + in_AttendeeName.ToString() + """,""idNumber"":""" + in_AttendeeId.ToString() + """,""documents"":[{""key"":""government_id"",""name"":""govt_id.pdf"",""docType"":""government_id""},{""key"":""photo"",""name"":""passport_photo.jpg"",""docType"":""photo""},{""key"":""payment_receipt"",""name"":""payment.pdf"",""docType"":""payment_receipt""}]}"]
              </InArgument>
            </Assign.Value>
          </Assign>

          <TryCatch DisplayName="4B — POST Register">
            <TryCatch.Try>
              <Sequence>
                <ui:HttpClient DisplayName="POST /events/:id/register"
                  RequestUrl="[in_ApiBaseURL.ToString() + &quot;/events/&quot; + in_EventId.ToString() + &quot;/register&quot;]"
                  Method="POST"
                  Body="[RegPayload]"
                  BodyFormat="application/json"
                  AcceptFormat="JSON"
                  Result="[RegResp]"
                  Timeout="10000" />

                <Assign DisplayName="Parse registration response">
                  <Assign.To><OutArgument x:TypeArguments="json:JObject">[RegObj]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="json:JObject">[json:JObject.Parse(RegResp)]</InArgument></Assign.Value>
                </Assign>

                <Assign DisplayName="Get Registration ID">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[RegId]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">[RegObj("id").ToString()]</InArgument></Assign.Value>
                </Assign>

                <ui:LogMessage Level="Info" Message="[&quot;  ✓ Registered — ID: &quot; + RegId]" />
              </Sequence>
            </TryCatch.Try>
            <TryCatch.Catches>
              <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
                <ActivityAction x:TypeArguments="s:Exception">
                  <ActivityAction.Argument><DelegateInArgument x:TypeArguments="s:Exception" Name="regEx" /></ActivityAction.Argument>
                  <ui:LogMessage Level="Error" Message="[&quot;  ✗ Registration failed: &quot; + regEx.Message]" />
                </ActivityAction>
              </Catch>
            </TryCatch.Catches>
          </TryCatch>

          <!-- ══ 4C: TRIGGER MOCK VERIFICATION ══ -->
          <If DisplayName="Have RegId?" Condition="[Not String.IsNullOrEmpty(RegId)]">
            <If.Then>
              <TryCatch DisplayName="4C — POST Verify Documents">
                <TryCatch.Try>
                  <Sequence>
                    <ui:LogMessage Level="Info" Message="&quot;  → Running mock document verification…&quot;" />

                    <ui:HttpClient DisplayName="POST /registrations/:id/verify"
                      RequestUrl="[in_ApiBaseURL.ToString() + &quot;/registrations/&quot; + RegId + &quot;/verify&quot;]"
                      Method="POST"
                      Body="&quot;{}&quot;"
                      BodyFormat="application/json"
                      AcceptFormat="JSON"
                      Result="[VerifyResp]"
                      Timeout="15000" />

                    <Assign DisplayName="Parse verify response">
                      <Assign.To><OutArgument x:TypeArguments="json:JObject">[VerifyObj]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="json:JObject">[json:JObject.Parse(VerifyResp)]</InArgument></Assign.Value>
                    </Assign>

                    <Assign DisplayName="Get certificate ready flag">
                      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[CertReady]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[CBool(VerifyObj("certificateReady"))]</InArgument></Assign.Value>
                    </Assign>

                    <ui:LogMessage Level="Info"
                      Message="[&quot;  → Verification: &quot; + VerifyObj(&quot;verificationStatus&quot;).ToString() + &quot; | Pass=&quot; + VerifyObj(&quot;passCount&quot;).ToString() + &quot; Fail=&quot; + VerifyObj(&quot;failCount&quot;).ToString()]" />

                    <If Condition="[CertReady]">
                      <If.Then>
                        <ui:LogMessage Level="Info" Message="&quot;  ✓ All documents verified — certificate is ready!&quot;" />
                      </If.Then>
                      <If.Else>
                        <ui:LogMessage Level="Warn" Message="&quot;  ⚠ Some documents failed — vendor review required&quot;" />
                      </If.Else>
                    </If>

                  </Sequence>
                </TryCatch.Try>
                <TryCatch.Catches>
                  <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
                    <ActivityAction x:TypeArguments="s:Exception">
                      <ActivityAction.Argument><DelegateInArgument x:TypeArguments="s:Exception" Name="vEx" /></ActivityAction.Argument>
                      <ui:LogMessage Level="Error" Message="[&quot;  ✗ Verification failed: &quot; + vEx.Message]" />
                    </ActivityAction>
                  </Catch>
                </TryCatch.Catches>
              </TryCatch>
            </If.Then>
          </If>

          <!-- Set output arguments -->
          <Assign DisplayName="Set out_RegistrationId">
            <Assign.To><OutArgument x:TypeArguments="x:String">[out_RegistrationId]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[RegId]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Set out_CertificateReady">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[out_CertificateReady]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">[CertReady]</InArgument></Assign.Value>
          </Assign>

        </Sequence>
      </If.Then>
      <If.Else>
        <ui:LogMessage Level="Error" Message="&quot;✗ Skipping registration — attendee not in event list&quot;" />
      </If.Else>
    </If>

  </Sequence>
</Activity>
