<Activity mc:Ignorable="sap sap2010 sads" x:Class="DownloadCertificates"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:json="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json">

  <x:Members>
    <x:Property Name="in_BaseURL" Type="InArgument(x:String)" />
    <x:Property Name="in_WebsiteURL" Type="InArgument(x:String)" />
  </x:Members>

  <Sequence DisplayName="Download All Approved Certificates">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="var_ApprovedJSON" />
      <Variable x:TypeArguments="json:JArray" Name="var_ApprovedApps" />
      <Variable x:TypeArguments="x:String" Name="var_CertResponse" />
      <Variable x:TypeArguments="x:String" Name="var_DownloadResponse" />
      <Variable x:TypeArguments="x:String" Name="var_CurrentId" />
      <Variable x:TypeArguments="x:String" Name="var_CurrentName" />
      <Variable x:TypeArguments="x:Int32" Name="var_DownloadCount" Default="0" />
    </Sequence.Variables>

    <ui:LogMessage DisplayName="Log — Starting Certificate Downloads" Level="Info"
      Message="&quot;Step 5: Downloading approved certificates...&quot;" />

    <!-- Fetch approved applications -->
    <TryCatch DisplayName="Fetch Approved Apps">
      <TryCatch.Try>
        <Sequence>
          <ui:HttpClient DisplayName="GET /api/applications?status=approved"
            Method="GET"
            RequestUrl="http://localhost:5000/api/applications?status=approved"
            Result="[var_ApprovedJSON]"
            AcceptFormat="JSON"
            Timeout="10000" />

          <Assign DisplayName="Parse Approved">
            <Assign.To><OutArgument x:TypeArguments="json:JArray">[var_ApprovedApps]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="json:JArray">[json:JArray.Parse(var_ApprovedJSON)]</InArgument></Assign.Value>
          </Assign>

          <ui:LogMessage Level="Info"
            Message="[String.Format(&quot;✓ Found {0} approved applications for certificate download&quot;, var_ApprovedApps.Count)]" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="ex" />
            </ActivityAction.Argument>
            <Sequence>
              <ui:LogMessage Level="Error" Message="&quot;✗ Failed to fetch approved apps: &quot; &amp; ex.Message" />
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="json:JArray">[var_ApprovedApps]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="json:JArray">[New json:JArray()]</InArgument></Assign.Value>
              </Assign>
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- Loop through and download each certificate -->
    <ForEach x:TypeArguments="json:JToken" DisplayName="For Each Approved App" Values="[var_ApprovedApps]">
      <ActivityAction x:TypeArguments="json:JToken">
        <ActivityAction.Argument>
          <DelegateInArgument x:TypeArguments="json:JToken" Name="approvedApp" />
        </ActivityAction.Argument>

        <TryCatch DisplayName="Download Certificate">
          <TryCatch.Try>
            <Sequence DisplayName="Fetch and Save Certificate">

              <Assign DisplayName="Get ID">
                <Assign.To><OutArgument x:TypeArguments="x:String">[var_CurrentId]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">[approvedApp("id").ToString()]</InArgument></Assign.Value>
              </Assign>
              <Assign DisplayName="Get Name">
                <Assign.To><OutArgument x:TypeArguments="x:String">[var_CurrentName]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">[approvedApp("fullName").ToString()]</InArgument></Assign.Value>
              </Assign>

              <ui:LogMessage Level="Info"
                Message="[String.Format(&quot;  → Downloading certificate for {0} ({1})&quot;, var_CurrentName, var_CurrentId)]" />

              <!-- Get certificate details -->
              <ui:HttpClient DisplayName="GET Certificate"
                Method="GET"
                RequestUrl="[&quot;http://localhost:5000/api/certificates/&quot; &amp; var_CurrentId]"
                Result="[var_CertResponse]"
                AcceptFormat="JSON"
                Timeout="10000" />

              <ui:LogMessage Level="Info"
                Message="[String.Format(&quot;  ✓ Certificate data retrieved: {0}&quot;, var_CertResponse.Substring(0, Math.Min(100, var_CertResponse.Length)) &amp; &quot;...&quot;)]" />

              <!-- Trigger download endpoint -->
              <ui:HttpClient DisplayName="GET Download"
                Method="GET"
                RequestUrl="[&quot;http://localhost:5000/api/certificates/&quot; &amp; var_CurrentId &amp; &quot;/download&quot;]"
                Result="[var_DownloadResponse]"
                AcceptFormat="JSON"
                Timeout="10000" />

              <ui:LogMessage Level="Info"
                Message="&quot;  ✓ Certificate download initiated: &quot; &amp; var_DownloadResponse" />

              <!-- Navigate to download page on website and enter tracking ID -->
              <TryCatch DisplayName="Try Website Download">
                <TryCatch.Try>
                  <Sequence DisplayName="Use Website Download Page">
                    <!-- Click Download nav -->
                    <ui:Click DisplayName="Click Download Nav"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl tag=&quot;A&quot; data-page=&quot;download&quot; /&gt;'}"
                      ContinueOnError="True" />
                    <Delay Duration="[TimeSpan.FromSeconds(1)]" />

                    <!-- Type tracking ID -->
                    <ui:TypeInto DisplayName="Type Tracking ID"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl id=&quot;downloadInput&quot; tag=&quot;INPUT&quot; /&gt;'}"
                      Text="[var_CurrentId]"
                      EmptyField="True"
                      ContinueOnError="True" />

                    <!-- Click Find -->
                    <ui:Click DisplayName="Click Find Button"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl tag=&quot;BUTTON&quot; innertext=&quot;*Find*&quot; /&gt;'}"
                      ContinueOnError="True" />
                    <Delay Duration="[TimeSpan.FromSeconds(2)]" />

                    <!-- Click Download PDF -->
                    <ui:Click DisplayName="Click Download PDF"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl tag=&quot;BUTTON&quot; innertext=&quot;*Download PDF*&quot; /&gt;'}"
                      ContinueOnError="True" />
                    <Delay Duration="[TimeSpan.FromSeconds(1)]" />

                    <ui:LogMessage Level="Info" Message="&quot;  ✓ Website certificate download triggered&quot;" />
                  </Sequence>
                </TryCatch.Try>
                <TryCatch.Catches>
                  <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
                    <ActivityAction x:TypeArguments="s:Exception">
                      <ActivityAction.Argument>
                        <DelegateInArgument x:TypeArguments="s:Exception" Name="uiEx" />
                      </ActivityAction.Argument>
                      <ui:LogMessage Level="Warn" Message="&quot;  ⚠ Website download UI interaction failed: &quot; &amp; uiEx.Message" />
                    </ActivityAction>
                  </Catch>
                </TryCatch.Catches>
              </TryCatch>

              <Assign DisplayName="Increment Download Count">
                <Assign.To><OutArgument x:TypeArguments="x:Int32">[var_DownloadCount]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Int32">[var_DownloadCount + 1]</InArgument></Assign.Value>
              </Assign>

            </Sequence>
          </TryCatch.Try>
          <TryCatch.Catches>
            <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
              <ActivityAction x:TypeArguments="s:Exception">
                <ActivityAction.Argument>
                  <DelegateInArgument x:TypeArguments="s:Exception" Name="dlEx" />
                </ActivityAction.Argument>
                <ui:LogMessage Level="Error"
                  Message="[String.Format(&quot;  ✗ Failed to download cert for {0}: {1}&quot;, var_CurrentId, dlEx.Message)]" />
              </ActivityAction>
            </Catch>
          </TryCatch.Catches>
        </TryCatch>

      </ActivityAction>
    </ForEach>

    <ui:LogMessage Level="Info"
      Message="[String.Format(&quot;✓ Certificate download complete — {0} certificates downloaded&quot;, var_DownloadCount)]" />

  </Sequence>
</Activity>
