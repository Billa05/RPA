<Activity mc:Ignorable="sap sap2010 sads" x:Class="OpenBrowserAndLogin"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <x:Members>
    <x:Property Name="in_WebsiteURL" Type="InArgument(x:String)" />
    <x:Property Name="in_AdminUser" Type="InArgument(x:String)" />
    <x:Property Name="in_AdminPass" Type="InArgument(x:String)" />
  </x:Members>

  <Sequence DisplayName="Open CertifyHub Website and Login to Admin Panel">
    <Sequence.Variables>
      <Variable x:TypeArguments="ui:Browser" Name="var_Browser" />
    </Sequence.Variables>

    <ui:LogMessage DisplayName="Log — Opening Browser" Level="Info"
      Message="&quot;Step 3: Opening CertifyHub website in browser...&quot;" />

    <!-- Open Browser -->
    <ui:OpenBrowser DisplayName="Open CertifyHub in Chrome"
      BrowserType="Chrome"
      Url="[in_WebsiteURL.ToString]"
      Browser="[var_Browser]">
      <ui:OpenBrowser.Body>
        <ActivityAction x:TypeArguments="ui:Browser">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="ui:Browser" Name="browser" />
          </ActivityAction.Argument>
          <Sequence DisplayName="Browser Actions">

            <!-- Wait for page to load -->
            <ui:BrowserScope DisplayName="Attach to CertifyHub" Browser="[var_Browser]">
              <ui:BrowserScope.Body>
                <ActivityAction>
                  <Sequence DisplayName="Navigate and Login">

                    <!-- Wait for homepage to load -->
                    <Delay Duration="[TimeSpan.FromSeconds(3)]" DisplayName="Wait for page load" />

                    <ui:LogMessage DisplayName="Log — Page Loaded" Level="Info"
                      Message="&quot;✓ CertifyHub homepage loaded successfully&quot;" />

                    <!-- Click Admin nav link -->
                    <ui:Click DisplayName="Click Admin Nav Link"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl tag=&quot;A&quot; data-page=&quot;admin&quot; /&gt;'}" />

                    <Delay Duration="[TimeSpan.FromSeconds(1)]" DisplayName="Wait for Admin page" />

                    <ui:LogMessage DisplayName="Log — Admin Page Open" Level="Info"
                      Message="&quot;✓ Navigated to Admin panel&quot;" />

                    <!-- Type Username -->
                    <ui:TypeInto DisplayName="Type Admin Username"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl id=&quot;adminUser&quot; tag=&quot;INPUT&quot; /&gt;'}"
                      Text="[in_AdminUser.ToString]"
                      EmptyField="True" />

                    <!-- Type Password -->
                    <ui:TypeInto DisplayName="Type Admin Password"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl id=&quot;adminPass&quot; tag=&quot;INPUT&quot; /&gt;'}"
                      Text="[in_AdminPass.ToString]"
                      EmptyField="True" />

                    <!-- Click Login Button -->
                    <ui:Click DisplayName="Click Login Button"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl tag=&quot;BUTTON&quot; innertext=&quot;*Login*&quot; /&gt;'}" />

                    <Delay Duration="[TimeSpan.FromSeconds(2)]" DisplayName="Wait for Admin Dashboard" />

                    <ui:LogMessage DisplayName="Log — Logged In" Level="Info"
                      Message="&quot;✓ Successfully logged into Admin panel&quot;" />

                    <!-- Verify admin dashboard is visible -->
                    <ui:ElementExists DisplayName="Check Admin Dashboard Loaded"
                      Target="{ui:Target Selector='&lt;html app=&quot;chrome.exe&quot; /&gt;&lt;webctrl id=&quot;adminDashboard&quot; /&gt;'}" />

                    <ui:LogMessage DisplayName="Log — Dashboard Confirmed" Level="Info"
                      Message="&quot;✓ Admin dashboard is visible — stats and table loaded&quot;" />

                  </Sequence>
                </ActivityAction>
              </ui:BrowserScope.Body>
            </ui:BrowserScope>

          </Sequence>
        </ActivityAction>
      </ui:OpenBrowser.Body>
    </ui:OpenBrowser>

  </Sequence>
</Activity>
