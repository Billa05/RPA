<Activity mc:Ignorable="sap sap2010 sads" x:Class="SeedTestData"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Sequence DisplayName="Seed Test Data into CertifyHub Backend">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="var_SeedResponse" />
      <Variable x:TypeArguments="x:String" Name="var_SeedURL" />
    </Sequence.Variables>

    <!-- Arguments -->
    <x:Members>
      <x:Property Name="in_BaseURL" Type="InArgument(x:String)" />
    </x:Members>

    <ui:LogMessage DisplayName="Log — Seeding Test Data" Level="Info"
      Message="&quot;Step 2: Seeding mock application data into backend...&quot;" />

    <!-- Call POST /api/seed -->
    <TryCatch DisplayName="Try Seed API Call">
      <TryCatch.Try>
        <Sequence DisplayName="Seed API">
          <Assign DisplayName="Build Seed URL">
            <Assign.To>
              <OutArgument x:TypeArguments="x:String">[var_SeedURL]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">[in_BaseURL.ToString &amp; "/seed"]</InArgument>
            </Assign.Value>
          </Assign>

          <ui:HttpClient DisplayName="POST /api/seed"
            Method="POST"
            RequestUrl="http://localhost:5000/api/seed"
            Result="[var_SeedResponse]"
            AcceptFormat="JSON"
            Timeout="15000"
            BodyFormat="application/json"
            Body="&quot;{}&quot;" />

          <ui:LogMessage DisplayName="Log — Seed Response" Level="Info"
            Message="&quot;✓ Seed Response: &quot; &amp; var_SeedResponse" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
            </ActivityAction.Argument>
            <ui:LogMessage DisplayName="Log — Seed Failed" Level="Warn"
              Message="&quot;⚠ Seed API failed (backend may be offline): &quot; &amp; exception.Message" />
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

  </Sequence>
</Activity>
