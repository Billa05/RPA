<Activity mc:Ignorable="sap sap2010 sads" x:Class="GenerateReport"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:sd="clr-namespace:System.Data;assembly=System.Data"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:json="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json">

  <x:Members>
    <x:Property Name="in_BaseURL" Type="InArgument(x:String)" />
    <x:Property Name="in_OutputPath" Type="InArgument(x:String)" />
    <x:Property Name="in_ProcessedCount" Type="InArgument(x:Int32)" />
    <x:Property Name="in_ApprovedCount" Type="InArgument(x:Int32)" />
    <x:Property Name="in_RejectedCount" Type="InArgument(x:Int32)" />
  </x:Members>

  <Sequence DisplayName="Generate Excel Report of All Applications">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="var_AllAppsJSON" />
      <Variable x:TypeArguments="json:JArray" Name="var_AllApps" />
      <Variable x:TypeArguments="sd:DataTable" Name="var_ReportTable" />
      <Variable x:TypeArguments="x:String" Name="var_StatsJSON" />
      <Variable x:TypeArguments="sd:DataTable" Name="var_SummaryTable" />
      <Variable x:TypeArguments="x:String" Name="var_VerLogJSON" />
    </Sequence.Variables>

    <ui:LogMessage DisplayName="Log — Generating Report" Level="Info"
      Message="&quot;Step 6: Generating Excel report...&quot;" />

    <!-- ======= BUILD REPORT DATA TABLE ======= -->
    <ui:BuildDataTable DisplayName="Build Report DataTable"
      DataTable="[var_ReportTable]"
      TableName="Applications">
      <ui:BuildDataTable.Columns>
        <ui:DataTableColumn ColumnName="Application ID" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Applicant Name" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Certificate Type" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Aadhaar" DataType="System.String" />
        <ui:DataTableColumn ColumnName="City" DataType="System.String" />
        <ui:DataTableColumn ColumnName="State" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Status" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Submitted At" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Verified By" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Verification Notes" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Documents Count" DataType="System.String" />
      </ui:BuildDataTable.Columns>
    </ui:BuildDataTable>

    <!-- Fetch all applications from backend -->
    <TryCatch DisplayName="Fetch All Apps for Report">
      <TryCatch.Try>
        <Sequence>
          <ui:HttpClient DisplayName="GET All Applications"
            Method="GET"
            RequestUrl="http://localhost:5000/api/applications"
            Result="[var_AllAppsJSON]"
            AcceptFormat="JSON"
            Timeout="10000" />

          <Assign DisplayName="Parse All Apps">
            <Assign.To><OutArgument x:TypeArguments="json:JArray">[var_AllApps]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="json:JArray">[json:JArray.Parse(var_AllAppsJSON)]</InArgument></Assign.Value>
          </Assign>

          <!-- Add each application as a row -->
          <ForEach x:TypeArguments="json:JToken" DisplayName="Add Rows" Values="[var_AllApps]">
            <ActivityAction x:TypeArguments="json:JToken">
              <ActivityAction.Argument>
                <DelegateInArgument x:TypeArguments="json:JToken" Name="reportApp" />
              </ActivityAction.Argument>
              <ui:AddDataRow DisplayName="Add Row"
                DataTable="[var_ReportTable]"
                ArrayRow="{x:Null}">
                <ui:AddDataRow.DataRow>
                  <InArgument x:TypeArguments="sd:DataRow">
                    [var_ReportTable.NewRow()]
                  </InArgument>
                </ui:AddDataRow.DataRow>
              </ui:AddDataRow>
            </ActivityAction>
          </ForEach>

          <ui:LogMessage Level="Info"
            Message="[String.Format(&quot;✓ Report data prepared: {0} rows&quot;, var_AllApps.Count)]" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="ex" />
            </ActivityAction.Argument>
            <ui:LogMessage Level="Error" Message="&quot;✗ Failed to fetch report data: &quot; &amp; ex.Message" />
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- ======= BUILD SUMMARY TABLE ======= -->
    <ui:BuildDataTable DisplayName="Build Summary Table"
      DataTable="[var_SummaryTable]"
      TableName="Summary">
      <ui:BuildDataTable.Columns>
        <ui:DataTableColumn ColumnName="Metric" DataType="System.String" />
        <ui:DataTableColumn ColumnName="Value" DataType="System.String" />
      </ui:BuildDataTable.Columns>
    </ui:BuildDataTable>

    <ui:AddDataRow DisplayName="Add Total Row" DataTable="[var_SummaryTable]"
      ArrayRow="[New Object() {&quot;Total Applications Processed&quot;, in_ProcessedCount.ToString()}]" />
    <ui:AddDataRow DisplayName="Add Approved Row" DataTable="[var_SummaryTable]"
      ArrayRow="[New Object() {&quot;Approved&quot;, in_ApprovedCount.ToString()}]" />
    <ui:AddDataRow DisplayName="Add Rejected Row" DataTable="[var_SummaryTable]"
      ArrayRow="[New Object() {&quot;Rejected&quot;, in_RejectedCount.ToString()}]" />
    <ui:AddDataRow DisplayName="Add Timestamp Row" DataTable="[var_SummaryTable]"
      ArrayRow="[New Object() {&quot;Report Generated At&quot;, DateTime.Now.ToString(&quot;yyyy-MM-dd HH:mm:ss&quot;)}]" />
    <ui:AddDataRow DisplayName="Add Bot Row" DataTable="[var_SummaryTable]"
      ArrayRow="[New Object() {&quot;Verified By&quot;, &quot;UiPath RPA Bot v1.0&quot;}]" />

    <!-- ======= WRITE TO EXCEL ======= -->
    <TryCatch DisplayName="Write Excel Report">
      <TryCatch.Try>
        <Sequence DisplayName="Excel Operations">
          <!-- Write Applications sheet -->
          <ui:ExcelWriteRange DisplayName="Write Applications Sheet"
            DataTable="[var_ReportTable]"
            SheetName="Applications"
            WorkbookPath="[in_OutputPath.ToString]"
            StartingCell="A1"
            AddHeaders="True" />

          <ui:LogMessage Level="Info" Message="&quot;✓ Applications sheet written&quot;" />

          <!-- Write Summary sheet -->
          <ui:ExcelWriteRange DisplayName="Write Summary Sheet"
            DataTable="[var_SummaryTable]"
            SheetName="Summary"
            WorkbookPath="[in_OutputPath.ToString]"
            StartingCell="A1"
            AddHeaders="True" />

          <ui:LogMessage Level="Info" Message="&quot;✓ Summary sheet written&quot;" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="excelEx" />
            </ActivityAction.Argument>
            <ui:LogMessage Level="Error"
              Message="&quot;✗ Excel write failed (Excel activities may not be installed): &quot; &amp; excelEx.Message" />
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- ======= FETCH VERIFICATION LOG ======= -->
    <TryCatch DisplayName="Fetch Verification Audit Log">
      <TryCatch.Try>
        <Sequence>
          <ui:HttpClient DisplayName="GET Verification Log"
            Method="GET"
            RequestUrl="http://localhost:5000/api/verification-log"
            Result="[var_VerLogJSON]"
            AcceptFormat="JSON"
            Timeout="10000" />

          <ui:LogMessage Level="Info"
            Message="&quot;✓ Verification audit log retrieved: &quot; &amp; var_VerLogJSON" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="logEx" />
            </ActivityAction.Argument>
            <ui:LogMessage Level="Warn" Message="&quot;⚠ Could not fetch audit log: &quot; &amp; logEx.Message" />
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <ui:LogMessage DisplayName="Log — Report Complete" Level="Info"
      Message="[String.Format(&quot;✓ Report generated at: {0}&quot;, in_OutputPath.ToString)]" />

  </Sequence>
</Activity>
