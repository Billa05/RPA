<Activity mc:Ignorable="sap sap2010" x:Class="CertifyHub.Main"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    CertifyHub RPA — Main Orchestrator (User Flow)
    ================================================
    Simulates a user:
      1. Opening the website and picking an event
      2. Entering their name + ID (attendance check)
      3. Uploading sample documents
      4. Waiting for mock verification results
      5. Downloading the certificate if approved
      6. Logging the result to a report
  -->

  <Sequence DisplayName="Main — CertifyHub User Flow Orchestrator">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="WebsiteURL"    Default="&quot;http://localhost:8080&quot;" />
      <Variable x:TypeArguments="x:String" Name="ApiBaseURL"    Default="&quot;http://localhost:5000/api&quot;" />
      <Variable x:TypeArguments="x:String" Name="HealthResp"    Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="EventId"       Default="&quot;EVT-DEMO1&quot;" />
      <Variable x:TypeArguments="x:String" Name="AttendeeName"  Default="&quot;Rajesh Kumar&quot;" />
      <Variable x:TypeArguments="x:String" Name="AttendeeId"    Default="&quot;ID001&quot;" />
      <Variable x:TypeArguments="x:String" Name="RegistrationId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Boolean" Name="CertificateReady" Default="False" />
      <Variable x:TypeArguments="x:Boolean" Name="BackendAlive"     Default="False" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="&quot;══════════════════════════════════════════&quot;" />
    <ui:LogMessage Level="Info" Message="&quot;  CertifyHub RPA — User Flow Started&quot;" />
    <ui:LogMessage Level="Info" Message="[&quot;  Timestamp: &quot; + DateTime.Now.ToString(&quot;yyyy-MM-dd HH:mm:ss&quot;)]" />
    <ui:LogMessage Level="Info" Message="&quot;══════════════════════════════════════════&quot;" />

    <!-- ── Step 1: Health Check ── -->
    <TryCatch DisplayName="Step 1 — Backend Health Check">
      <TryCatch.Try>
        <Sequence>
          <ui:HttpClient DisplayName="GET /api/health"
            RequestUrl="[ApiBaseURL + &quot;/health&quot;]"
            Method="GET"
            Result="[HealthResp]"
            AcceptFormat="JSON"
            Timeout="8000" />
          <Assign DisplayName="Mark backend alive">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[BackendAlive]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">True</InArgument></Assign.Value>
          </Assign>
          <ui:LogMessage Level="Info" Message="[&quot;✓ Backend healthy: &quot; + HealthResp]" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="ex" />
            </ActivityAction.Argument>
            <Sequence>
              <ui:LogMessage Level="Error" Message="[&quot;✗ Backend unreachable: &quot; + ex.Message]" />
              <ui:LogMessage Level="Warn"  Message="&quot;Make sure backend is running: cd backend &amp;&amp; python app.py&quot;" />
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- ── Step 2: Seed demo data ── -->
    <InvokeWorkflowFile DisplayName="Step 2 — Seed Demo Data"
      WorkflowFileName="Workflows\SeedDemoData.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_ApiBaseURL">[ApiBaseURL]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ── Step 3: Open browser and navigate to event ── -->
    <InvokeWorkflowFile DisplayName="Step 3 — Open Event on Website"
      WorkflowFileName="Workflows\OpenEventPage.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_WebsiteURL">[WebsiteURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_EventId">[EventId]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ── Step 4: Check attendance and upload documents ── -->
    <InvokeWorkflowFile DisplayName="Step 4 — Register and Upload Documents"
      WorkflowFileName="Workflows\RegisterAndUpload.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_ApiBaseURL">[ApiBaseURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_EventId">[EventId]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_AttendeeName">[AttendeeName]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_AttendeeId">[AttendeeId]</InArgument>
        <OutArgument x:TypeArguments="x:String"  x:Key="out_RegistrationId">[RegistrationId]</OutArgument>
        <OutArgument x:TypeArguments="x:Boolean" x:Key="out_CertificateReady">[CertificateReady]</OutArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ── Step 5: Download certificate (if ready) ── -->
    <If DisplayName="Step 5 — Certificate Ready?" Condition="[CertificateReady]">
      <If.Then>
        <InvokeWorkflowFile DisplayName="Download Certificate"
          WorkflowFileName="Workflows\DownloadCertificate.xaml">
          <InvokeWorkflowFile.Arguments>
            <InArgument x:TypeArguments="x:String" x:Key="in_ApiBaseURL">[ApiBaseURL]</InArgument>
            <InArgument x:TypeArguments="x:String" x:Key="in_RegistrationId">[RegistrationId]</InArgument>
            <InArgument x:TypeArguments="x:String" x:Key="in_WebsiteURL">[WebsiteURL]</InArgument>
          </InvokeWorkflowFile.Arguments>
        </InvokeWorkflowFile>
      </If.Then>
      <If.Else>
        <ui:LogMessage Level="Warn" Message="[&quot;⚠ Certificate not ready for &quot; + RegistrationId + &quot; — may need vendor review&quot;]" />
      </If.Else>
    </If>

    <!-- ── Step 6: Generate Report ── -->
    <InvokeWorkflowFile DisplayName="Step 6 — Generate Report"
      WorkflowFileName="Workflows\GenerateReport.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String"  x:Key="in_ApiBaseURL">[ApiBaseURL]</InArgument>
        <InArgument x:TypeArguments="x:String"  x:Key="in_RegistrationId">[RegistrationId]</InArgument>
        <InArgument x:TypeArguments="x:Boolean" x:Key="in_CertificateReady">[CertificateReady]</InArgument>
        <InArgument x:TypeArguments="x:String"  x:Key="in_AttendeeName">[AttendeeName]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <ui:LogMessage Level="Info" Message="&quot;══════════════════════════════════════════&quot;" />
    <ui:LogMessage Level="Info" Message="[&quot;  CertifyHub RPA — Completed at &quot; + DateTime.Now.ToString(&quot;HH:mm:ss&quot;)]" />
    <ui:LogMessage Level="Info" Message="[&quot;  Registration: &quot; + RegistrationId + &quot;  |  Certificate: &quot; + CertificateReady.ToString()]" />
    <ui:LogMessage Level="Info" Message="&quot;══════════════════════════════════════════&quot;" />

  </Sequence>
</Activity>
