<Activity mc:Ignorable="sap sap2010 sads" x:Class="Main"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <TextExpression.NamespacesForImplementation>
    <scg:List x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>System.Linq</x:String>
      <x:String>UiPath.Core.Activities</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
    </scg:List>
  </TextExpression.NamespacesForImplementation>

  <Sequence DisplayName="CertifyHub RPA — Main Orchestrator" sap2010:WorkflowViewState.IdRef="MainSequence_1">

    <!-- ============ GLOBAL VARIABLES ============ -->
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="var_BaseURL" Default="http://localhost:5000/api" />
      <Variable x:TypeArguments="x:String" Name="var_WebsiteURL" Default="http://localhost:8080" />
      <Variable x:TypeArguments="x:String" Name="var_AdminUser" Default="admin" />
      <Variable x:TypeArguments="x:String" Name="var_AdminPass" Default="admin123" />
      <Variable x:TypeArguments="x:String" Name="var_OutputExcelPath" Default="Reports\CertifyHub_Report.xlsx" />
      <Variable x:TypeArguments="x:String" Name="var_HealthStatus" />
      <Variable x:TypeArguments="x:String" Name="var_SeedResponse" />
      <Variable x:TypeArguments="x:Int32" Name="var_ProcessedCount" Default="0" />
      <Variable x:TypeArguments="x:Int32" Name="var_ApprovedCount" Default="0" />
      <Variable x:TypeArguments="x:Int32" Name="var_RejectedCount" Default="0" />
      <Variable x:TypeArguments="x:Boolean" Name="var_BackendAlive" Default="False" />
    </Sequence.Variables>

    <!-- ============ STEP 0: LOG START ============ -->
    <ui:LogMessage DisplayName="Log — Workflow Started" Level="Info"
      Message="[String.Format(&quot;========== CertifyHub RPA Started at {0} ==========&quot;, DateTime.Now.ToString())]" />

    <!-- ============ STEP 1: HEALTH CHECK ============ -->
    <TryCatch DisplayName="Step 1: Health Check">
      <TryCatch.Try>
        <Sequence DisplayName="Check Backend Health">
          <ui:LogMessage DisplayName="Log — Checking Backend" Level="Info"
            Message="&quot;Step 1: Checking backend health at &quot; &amp; var_BaseURL &amp; &quot;/health&quot;" />

          <ui:HttpClient DisplayName="GET /api/health"
            Method="GET"
            EndPoint="{x:Null}"
            RequestUrl="http://localhost:5000/api/health"
            Result="[var_HealthStatus]"
            AcceptFormat="JSON"
            Timeout="10000" />

          <ui:LogMessage DisplayName="Log — Health Response" Level="Info"
            Message="&quot;Health Check Response: &quot; &amp; var_HealthStatus" />

          <Assign DisplayName="Set BackendAlive = True">
            <Assign.To>
              <OutArgument x:TypeArguments="x:Boolean">[var_BackendAlive]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:Boolean">True</InArgument>
            </Assign.Value>
          </Assign>

          <ui:LogMessage DisplayName="Log — Backend Online" Level="Info"
            Message="&quot;✓ Backend is healthy and responding&quot;" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
            </ActivityAction.Argument>
            <Sequence DisplayName="Handle Health Check Failure">
              <ui:LogMessage DisplayName="Log — Backend Offline" Level="Error"
                Message="&quot;✗ Backend health check failed: &quot; &amp; exception.Message" />
              <ui:LogMessage Level="Warn" Message="&quot;Attempting to continue with website-only mode...&quot;" />
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- ============ STEP 2: SEED TEST DATA ============ -->
    <InvokeWorkflowFile DisplayName="Step 2: Seed Test Data"
      WorkflowFileName="SeedTestData.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_BaseURL">[var_BaseURL]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ============ STEP 3: OPEN BROWSER & LOGIN ============ -->
    <InvokeWorkflowFile DisplayName="Step 3: Open Browser and Login to Admin"
      WorkflowFileName="OpenBrowserAndLogin.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_WebsiteURL">[var_WebsiteURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_AdminUser">[var_AdminUser]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_AdminPass">[var_AdminPass]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ============ STEP 4: PROCESS ALL APPLICATIONS ============ -->
    <InvokeWorkflowFile DisplayName="Step 4: Process Pending Applications"
      WorkflowFileName="ProcessApplications.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_BaseURL">[var_BaseURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_WebsiteURL">[var_WebsiteURL]</InArgument>
        <OutArgument x:TypeArguments="x:Int32" x:Key="out_ProcessedCount">[var_ProcessedCount]</OutArgument>
        <OutArgument x:TypeArguments="x:Int32" x:Key="out_ApprovedCount">[var_ApprovedCount]</OutArgument>
        <OutArgument x:TypeArguments="x:Int32" x:Key="out_RejectedCount">[var_RejectedCount]</OutArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ============ STEP 5: DOWNLOAD APPROVED CERTIFICATES ============ -->
    <InvokeWorkflowFile DisplayName="Step 5: Download Approved Certificates"
      WorkflowFileName="DownloadCertificates.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_BaseURL">[var_BaseURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_WebsiteURL">[var_WebsiteURL]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ============ STEP 6: GENERATE REPORT ============ -->
    <InvokeWorkflowFile DisplayName="Step 6: Generate Excel Report"
      WorkflowFileName="GenerateReport.xaml">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_BaseURL">[var_BaseURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_OutputPath">[var_OutputExcelPath]</InArgument>
        <InArgument x:TypeArguments="x:Int32" x:Key="in_ProcessedCount">[var_ProcessedCount]</InArgument>
        <InArgument x:TypeArguments="x:Int32" x:Key="in_ApprovedCount">[var_ApprovedCount]</InArgument>
        <InArgument x:TypeArguments="x:Int32" x:Key="in_RejectedCount">[var_RejectedCount]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- ============ STEP 7: FINAL SUMMARY ============ -->
    <ui:LogMessage DisplayName="Log — Final Summary" Level="Info"
      Message="[String.Format(&quot;========== CertifyHub RPA Complete ==========&#xA;Processed: {0} | Approved: {1} | Rejected: {2}&#xA;Finished at: {3}&quot;, var_ProcessedCount, var_ApprovedCount, var_RejectedCount, DateTime.Now.ToString())]" />

  </Sequence>
</Activity>
